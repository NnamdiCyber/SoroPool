# SoroPool Environment Configuration

# Backend
BACKEND_PORT=3000
BACKEND_WS_PORT=3001

# Database (TimescaleDB / PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=soropool
DATABASE_USER=soropool
DATABASE_PASSWORD=change_me
DATABASE_SSL=false
DATABASE_POOL_SIZE=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_TTL_SECONDS=300

# RabbitMQ
RABBITMQ_URL=amqp://soropool:change_me@localhost:5672

# JWT
JWT_SECRET=your_minimum_32_character_secret_key_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract Addresses
CONTRACT_POOL_FACTORY=
CONTRACT_ROUTER=
CONTRACT_FARM=
CONTRACT_GOVERNANCE=
CONTRACT_SPL_TOKEN=

# Indexer
INDEXER_START_LEDGER=1000000
INDEXER_BATCH_SIZE=100
INDEXER_POLL_INTERVAL_MS=5000

# Oracle
TWAP_WINDOW_SECONDS=1800
ORACLE_REFRESH_INTERVAL_SEC=60
MAX_PRICE_DEVIATION_PCT=5

# Routing
MAX_HOPS=3
MAX_ROUTES_CONSIDERED=20
ROUTING_CACHE_TTL_MS=2000

# Notifications
SENDGRID_API_KEY=
FROM_EMAIL=noreply@soropool.finance

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
